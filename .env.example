# =================================================================
# MJU Capstone Backend Environment Variables Example
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요.
# .env 파일은 보안을 위해 절대 GitHub에 올리지 마세요.
# =================================================================

# 1. Database (Supabase PostgreSQL)
# DB_URL 형식: jdbc:postgresql://<HOST>:<PORT>/postgres?prepareThreshold=0
DB_URL=jdbc:postgresql://your-supabase-host:6543/postgres?prepareThreshold=0
DB_USERNAME=postgres.your-project-id
DB_PASSWORD=your-supabase-password

# 2. Redis (Upstash)
# REDIS_HOST: Upstash 콘솔에서 제공하는 Endpoint 주소 (포트 제외)
REDIS_HOST=your-upstash-endpoint.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password-token

# 3. AI Agent Server (FastAPI)
# 백엔드가 AI 에이전트 서버와 통신하기 위한 주소
AI_AGENT_URL=http://localhost:8000

## Postgres 스레드와 커넥션 개수
DB_POOL_SIZE=20

# Clerk 설정
CLERK_JWKS_URL=your-clerk-url
CLERK_ISSUER=your-clerk-issuer
CLERK_SECRET_KEY=your-clerk-key